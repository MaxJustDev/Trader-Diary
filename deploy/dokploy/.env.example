# TraderDiary — Dokploy environment (paste into Dokploy → app → Environment).
# These feed docker-compose.yml at the repo root.

# REQUIRED. Fernet key for encrypting stored MT5 passwords.
# Generate once and NEVER change it (losing it = saved passwords unreadable):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Where the Wine MT5 bridge listens (on the host). Leave as host.docker.internal
# unless the bridge runs on a different machine — then put that IP here.
MT5_BRIDGE_HOST=host.docker.internal
MT5_BRIDGE_PORT=8765

# One Wine terminal at a time (RAM). Raise only if the host has spare RAM AND
# you run multiple bridge instances (not supported by the single bridge yet).
MAX_ACTIVE_ACCOUNTS=1
LOW_RESOURCE_MODE=1

# Stealth order mode: off | tier1 | tier2 (tier2 = design-only).
STEALTH_MODE=tier1
