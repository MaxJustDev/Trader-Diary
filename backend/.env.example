# TraderDiary backend environment
#
# Copy this file to `.env` (same directory) and fill in real values.
# `.env` is gitignored — never commit it.

# ── Required ────────────────────────────────────────────────────────────────
# Fernet symmetric key used to encrypt MT5 passwords stored in SQLite.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# If you lose this key, every saved MT5 password becomes unrecoverable.
# Back it up alongside your traderdiary.db file.
ENCRYPTION_KEY=

# ── Optional ────────────────────────────────────────────────────────────────
# Path to the MetaTrader 5 install used as the BASE template for per-account
# terminal copies. Defaults to the standard Windows install path.
# MT5_BASE_PATH=C:\Program Files\MetaTrader 5

# Directory where per-account terminal copies are stored. Each MT5 account in
# TraderDiary gets its own subdirectory `Account {id} MT5 Terminal\` here.
# MT5_TERMINALS_DIR=C:\Program Files
